# Bookworm Web Service 配置
# 使用方式: cp env.example .env && 编辑 .env

# 服务端口
PORT=3211

# JWT 签名密钥 (生产环境请用 64 字符随机字符串)
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-random-64-char-string

# BYOK API Key 加密主密钥 (32 字节 hex，生产环境必须更换)
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=change-me-to-random-64-char-hex-string

# Bookworm 技能索引路径 (只读引用，不修改任何 .claude 文件)
BOOKWORM_SKILLS_INDEX=C:\Users\janson9527us\.claude\skills-index.json

# Claude API 基础 URL (用户可指定自定义中转)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 限流: 每用户每分钟最大请求数
RATE_LIMIT_RPM=30

# 最大请求体大小 (字节)
MAX_BODY_SIZE=524288
